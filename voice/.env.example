# Copy to .env and fill in. The .env file is gitignored.
# voice/server.py reads this at startup via pydantic-settings.

# ── Voice stack (cloud streaming, ~1-2s round-trip per turn) ──────────
# Sign up: https://console.deepgram.com   (free $200 trial credit)
DEEPGRAM_API_KEY=

# Sign up: https://elevenlabs.io/app/settings/api-keys   (free tier OK for demos)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Telephony (Twilio) ────────────────────────────────────────────────
# Console: https://console.twilio.com   (free trial $15)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── LLM (Gemma 4 via Ollama on Spark, through the existing gemma-proxy) ─
# When this voice service runs on Spark itself:
#   OLLAMA_BASE_URL=http://localhost:11434/v1
# When it runs on the tablet (default — the arm is on COM10 here):
#   Point at the bore.pub tunnel from scripts/deploy_bore_tunnel.sh
#   OLLAMA_BASE_URL=https://bore.pub:<port>/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=gemma4:26b-a4b-it-q4

# ── Orchestrator passthrough ──────────────────────────────────────────
# The orchestrator's own env vars. Keep model + host consistent with
# the voice service so look_at_scene and select_next_skill hit the
# same Gemma instance.
GEMMA_MODEL=gemma4:26b-a4b-it-q4
OLLAMA_HOST=http://localhost:11434
GEMMA_PROXY_TOKEN=
CAMERA_INDEX=1
FOLLOWER_PORT=COM10
LEADER_PORT=COM7
VERIFY_INTERVAL_S=3.0
SKILL_TIMEOUT_S=30.0

# ── Public ingress (where Twilio dials in) ────────────────────────────
# Either Tailscale Funnel host or a bore.pub tunnel URL.
# bore: bore local 8765 --to bore.pub
WEBHOOK_HOST=https://<your-public-host>

# ── Server ────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
LOG_LEVEL=INFO
CONFIRM_BEFORE_EXECUTE=true
